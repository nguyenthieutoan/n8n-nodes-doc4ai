{
  "name": "n8n-nodes-doc4ai",
  "version": "1.0.6",
  "description": "n8n community node for Doc4AI: Extract text from PDF, DOC, DOCX, XLS, XLSX, CSV, and convert text back to documents.",
  "license": "MIT",
  "author": {
    "name": "Jay Nguyen (Nguyễn Thiệu Toàn)",
    "email": "me@nguyenthieutoan.com",
    "url": "https://nguyenthieutoan.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nguyenthieutoan/n8n-nodes-doc4ai.git"
  },
  "bugs": {
    "url": "https://github.com/nguyenthieutoan/n8n-nodes-doc4ai/issues"
  },
  "homepage": "https://github.com/nguyenthieutoan/n8n-nodes-doc4ai#readme",
  "keywords": [
    "n8n-community-node-package"
  ],
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild index.ts nodes/Doc4AI/Doc4AI.node.ts --bundle --platform=node --target=node22 --outdir=dist --external:n8n-workflow --external:@n8n/ai-utilities && gulp build:icons",
    "dev": "tsc --watch",
    "test": "jest --forceExit",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.22.0"
  },
  "n8n": {
    "nodes": [
      "dist/nodes/Doc4AI/Doc4AI.node.js"
    ]
  },
  "dependencies": {},
  "peerDependencies": {
    "n8n-workflow": "^1.0.0"
  },
  "devDependencies": {
    "@n8n/node-cli": "^0.23.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@types/pdf-parse": "^1.1.4",
    "esbuild": "^0.20.0",
    "gulp": "^4.0.2",
    "jest": "^29.0.0",
    "mammoth": "^1.7.2",
    "n8n-workflow": "^1.0.0",
    "pdf-parse": "^1.1.1",
    "ts-jest": "^29.0.0",
    "turndown": "^7.1.3",
    "typescript": "^5.0.0",
    "word-extractor": "^1.0.4",
    "xlsx": "^0.18.5"
  }
}
